    <PackageVersion Include="SourceKit.Analyzers.Nullable" Version="1.0.52" />
    <PackageVersion Include="SourceKit.Analyzers.Properties" Version="1.0.52" />
    <PackageVersion Include="Itmo.Dev.Editorconfig" Version="1.0.14" />
    <PackageVersion Include="SourceKit.Generators.Builder" Version="1.2.54" />
    <PackageVersion Include="SourceKit.Generators.Builder.Annotations" Version="1.1.54" />
    <PackageVersion Include="SourceKit.Generators.Grpc" Version="1.0.58" />
    <PackageVersion Include="Spectre.Console.Cli" Version="0.53.1" />
    <PackageVersion Include="Spectre.Console.Registrars.Microsoft-Di" Version="0.6.0" />
    <PackageVersion Include="StyleCop.Analyzers" Version="1.2.0-beta.556" />
