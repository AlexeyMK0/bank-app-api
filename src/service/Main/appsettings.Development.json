{
  "Infrastructure": {
    "Persistence": {
      "Postgres": {
        "Host": "localhost",
        "Port": 5432,
        "Database": "postgres",
        "Username": "postgres",
        "Password": "postgres",
        "SslMode": "Prefer",
        "Pooling": true
      }
    }
  },
  "Controllers": {
    "Invoices": {
      "DefaultPageSize": 5
    },
    "Operations": {
      "DefaultPageSize": 2
    }
  },
  "Kestrel": {
    "Endpoints": {
      "gRpcEndpoint": {
        "Url": "http://localhost:5000",
        "Protocols": "Http2"
      }
    }
  }
}